generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SkillCategory {
  PROGRAMMING_LANGUAGES
  BACKEND
  FRONTEND
  DATABASES
  CLOUD
  DEVOPS
  AI
  DATA_ENGINEERING
  TESTING
  ARCHITECTURE
  TOOLS
}

enum KeywordCategory {
  SKILL
  EXPERIENCE
  PROJECT
  ROLE
  DOMAIN
  TOOL
}

enum EmbeddingEntityType {
  RESUME
  EXPERIENCE
  PROJECT
  SKILL
}

model Candidate {
  id                      String                @id @default(uuid())
  fullName                String
  email                   String?
  phone                   String?
  location                String?
  linkedIn                String?
  github                  String?
  portfolio               String?
  summary                 String?
  resumeText              String?
  searchQueries           String[]              @default([])
  topStrengths            String[]              @default([])
  uniqueAdvantages        String[]              @default([])
  competitiveAdvantages   String[]              @default([])
  startupFitScore         Int                   @default(0)
  enterpriseFitScore      Int                   @default(0)
  remoteWorkFitScore      Int                   @default(0)
  leadershipScore         Int                   @default(0)
  ownershipScore          Int                   @default(0)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  skills                  CandidateSkill[]
  projects                CandidateProject[]
  experiences             CandidateExperience[]
  education               CandidateEducation[]
  keywords                CandidateKeyword[]
  roles                   CandidateRole[]
  embeddings              CandidateEmbedding[]
  matches                 JobMatch[]
  referralTargets         ReferralTarget[]
  outreachDrafts          OutreachDraft[]
  resumeVersions          ResumeVersion[]
  resumeGenerationRuns    ResumeGenerationRun[]
  applications            Application[]
  communications          Communication[]

  @@index([email])
  @@index([fullName])
}

model CandidateSkill {
  id                 String        @id @default(uuid())
  candidateId        String
  skillName          String
  category           SkillCategory
  confidenceScore    Float
  yearsOfExperience  Float?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  candidate          Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([skillName])
  @@index([category])
}

model CandidateProject {
  id              String    @id @default(uuid())
  candidateId     String
  projectName     String
  description     String?
  techStack       String[]  @default([])
  projectType     String?
  role            String?
  githubLink      String?
  liveLink        String?
  businessImpact  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([projectName])
}

model CandidateExperience {
  id                 String    @id @default(uuid())
  candidateId        String
  company            String
  role               String
  startDate          String?
  endDate            String?
  responsibilities   String[]  @default([])
  technologiesUsed   String[]  @default([])
  achievements       String[]  @default([])
  impactMetrics      String[]  @default([])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  candidate          Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([company])
  @@index([role])
}

model CandidateEducation {
  id                    String    @id @default(uuid())
  candidateId           String
  degree                String
  university            String
  startYear             Int?
  endYear               Int?
  relevantCoursework    String[]  @default([])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  candidate             Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([university])
}

model CandidateKeyword {
  id            String          @id @default(uuid())
  candidateId   String
  keyword       String
  category      KeywordCategory
  weight        Float
  source        String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  candidate     Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([keyword])
  @@index([category])
}

model CandidateRole {
  id                 String    @id @default(uuid())
  candidateId        String
  roleName           String
  confidenceScore    Int
  searchQueries      String[]  @default([])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  candidate          Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([roleName])
}

model CandidateEmbedding {
  id              String              @id @default(uuid())
  candidateId     String
  entityType      EmbeddingEntityType
  entityLabel     String
  sourceText      String
  embedding       Float[]
  provider        String
  model           String
  dimensions      Int
  createdAt       DateTime            @default(now())
  candidate       Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([entityType])
}

enum RemoteStatus {
  REMOTE
  HYBRID
  ONSITE
  UNKNOWN
}

model Job {
  id                        String              @id @default(uuid())
  jobId                     String              @unique @default(uuid()) @map("job_id")
  title                     String
  company                   String
  description               String
  applicationUrl            String?             @map("application_url")
  companyUrl                String?             @map("company_url")
  location                  String?
  employmentType            String?             @map("employment_type")
  experienceRequired        String?             @map("experience_required")
  experienceClassification  String?             @map("experience_classification")
  salaryMin                 Float?              @map("salary_min")
  salaryMax                 Float?              @map("salary_max")
  remoteStatus              RemoteStatus        @default(UNKNOWN) @map("remote_status")
  postedDate                DateTime?           @map("posted_date")
  source                    String
  sourceJobId               String?             @map("source_job_id")
  crawlTimestamp            DateTime            @default(now()) @map("crawl_timestamp")
  status                    String              @default("ACTIVE")
  freshnessScore            Int                 @default(0) @map("freshness_score")
  createdAt                 DateTime            @default(now()) @map("created_at")
  updatedAt                 DateTime            @updatedAt @map("updated_at")

  // Relationships
  jobSourceId               String?             @map("job_source_id")
  jobSource                 JobSource?          @relation(fields: [jobSourceId], references: [id], onDelete: SetNull)
  locations                 JobLocation[]
  technologies              JobTechnology[]     @relation("JobToTechnology")
  tags                      JobTag[]            @relation("JobToTag")
  salary                    JobSalary?
  match                     JobMatch?
  referralTargets           ReferralTarget[]
  discoveryRuns             ContactDiscoveryRun[]
  outreachDrafts            OutreachDraft[]
  resumeVersions            ResumeVersion[]
  resumeGenerationRuns      ResumeGenerationRun[]
  applications              Application[]

  @@index([company])
  @@index([title])
  @@index([source])
  @@index([status])
  @@index([remoteStatus])
  @@index([experienceClassification])
}

model JobSource {
  id              String    @id @default(uuid())
  name            String    @unique
  baseUrl         String?   @map("base_url")
  lastCrawledAt   DateTime? @map("last_crawled_at")
  freshnessScore  Float     @default(0) @map("freshness_score")
  isActive        Boolean   @default(true) @map("is_active")
  jobs            Job[]
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
}

model JobLocation {
  id            String       @id @default(uuid())
  jobId         String       @map("job_id")
  city          String?
  state         String?
  country       String?
  rawLocation   String       @map("raw_location")
  remoteStatus  RemoteStatus @default(UNKNOWN) @map("remote_status")
  job           Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([jobId])
}

model JobTechnology {
  id        String   @id @default(uuid())
  name      String   @unique
  jobs      Job[]    @relation("JobToTechnology")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([name])
}

model JobSalary {
  id        String   @id @default(uuid())
  jobId     String   @unique @map("job_id")
  currency  String   @default("USD")
  min       Float?
  max       Float?
  interval  String   @default("YEAR") // HOURLY, YEAR, MONTH
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model JobTag {
  id        String   @id @default(uuid())
  name      String
  category  String
  jobs      Job[]    @relation("JobToTag")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, category])
}

model JobSearchRun {
  id          String   @id @default(uuid())
  searchQuery String   @map("search_query")
  source      String
  jobsFound   Int      @default(0) @map("jobs_found")
  jobsAdded   Int      @default(0) @map("jobs_added")
  jobsUpdated Int      @default(0) @map("jobs_updated")
  errors      String?
  duration    Int      @default(0)
  status      String   @default("SUCCESS") // SUCCESS, FAILED, RUNNING
  createdAt   DateTime @default(now()) @map("created_at")
}

model JobMatch {
  id                      String              @id @default(uuid())
  jobId                   String              @unique @map("job_id")
  candidateId             String              @map("candidate_id")
  matchScore              Float               @map("match_score")
  rankingScore            Float               @map("ranking_score")
  classification          String              @map("classification") // EXCELLENT, GOOD, AVERAGE, POOR

  skillsMatchScore        Float               @map("skills_match_score")
  experienceMatchScore    Float               @map("experience_match_score")
  projectMatchScore       Float               @map("project_match_score")
  roleMatchScore          Float               @map("role_match_score")
  startupFitScore         Float               @map("startup_fit_score")
  locationFitScore        Float               @map("location_fit_score")
  compensationFitScore    Float               @map("compensation_fit_score")

  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")

  // Relationships
  job                     Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate               Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  reasons                 JobMatchReason[]
  recommendation          JobRecommendation?

  @@index([candidateId])
  @@index([classification])
  @@index([matchScore])
  @@index([rankingScore])
}

model JobMatchReason {
  id          String   @id @default(uuid())
  jobMatchId  String   @map("job_match_id")
  reason      String
  isPositive  Boolean  @default(true) @map("is_positive")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relationship
  jobMatch    JobMatch @relation(fields: [jobMatchId], references: [id], onDelete: Cascade)

  @@index([jobMatchId])
}

model JobRecommendation {
  id                        String   @id @default(uuid())
  jobMatchId                String   @unique @map("job_match_id")
  whyApply                  String[] @default([]) @map("why_apply")
  whyNotApply               String[] @default([]) @map("why_not_apply")
  riskFactors               String[] @default([]) @map("risk_factors")
  strengths                 String[] @default([]) @map("strengths")
  weaknesses                String[] @default([]) @map("weaknesses")
  preparationTips           String[] @default([]) @map("preparation_tips")
  interviewReadinessScore   Int      @map("interview_readiness_score")
  missingSkills             String[] @default([]) @map("missing_skills")
  presentSkills             String[] @default([]) @map("present_skills")
  improvementRecommendations String[] @default([]) @map("improvement_recommendations")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  // Relationship
  jobMatch                  JobMatch @relation(fields: [jobMatchId], references: [id], onDelete: Cascade)
}

model Company {
  id                  String                @id @default(uuid())
  companyName         String                @unique @map("company_name")
  website             String?
  linkedinUrl         String?               @map("linkedin_url")
  careersUrl          String?               @map("careers_url")
  industry            String?
  companySize         String?               @map("company_size")
  headquarters        String?
  fundingStage        String?               @map("funding_stage")
  description         String?
  headcount           Int?
  hiringActivity      String?               @map("hiring_activity")
  recentGrowthSignals String?               @map("recent_growth_signals")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  // Relations
  contacts            CompanyContact[]
  departments         CompanyDepartment[]
  discoveryRuns       ContactDiscoveryRun[]
  applications        Application[]
  communications      Communication[]
  communicationThreads CommunicationThread[]

  @@index([companyName])
}

model CompanyDepartment {
  id          String           @id @default(uuid())
  companyId   String           @map("company_id")
  name        String
  headcount   Int?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  // Relations
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contacts    CompanyContact[]

  @@unique([companyId, name])
  @@index([companyId])
}

enum ContactCategory {
  HIRING_MANAGER
  ENGINEERING_MANAGER
  TEAM_LEAD
  RECRUITER
  FOUNDER
  CTO
  ENGINEER
  REFERRAL_SOURCE
  OTHER
}

model CompanyContact {
  id              String             @id @default(uuid())
  companyId       String             @map("company_id")
  fullName        String             @map("full_name")
  jobTitle        String             @map("job_title")
  departmentId    String?            @map("department_id")
  departmentName  String?            @map("department_name")
  seniority       String?
  linkedinUrl     String?            @map("linkedin_url")
  companyName     String             @map("company_name")
  source          String
  confidenceScore Float              @map("confidence_score")
  contactPriority Float              @map("contact_priority")
  category        ContactCategory
  status          String             @default("DISCOVERED")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  // Relations
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      CompanyDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  discoveryRunId  String?            @map("discovery_run_id")
  discoveryRun    ContactDiscoveryRun? @relation(fields: [discoveryRunId], references: [id], onDelete: SetNull)
  referrals       ReferralTarget[]
  outreachDrafts  OutreachDraft[]
  applications    Application[]
  communications  Communication[]
  communicationThreads CommunicationThread[]
  followUpSchedules FollowUpSchedule[]

  @@index([companyId])
  @@index([departmentId])
  @@index([discoveryRunId])
  @@index([category])
  @@index([contactPriority])
}

model ReferralTarget {
  id          String         @id @default(uuid())
  contactId   String         @map("contact_id")
  candidateId String         @map("candidate_id")
  jobId       String         @map("job_id")
  ranking     Int
  type        String         // SAME_TEAM, SAME_DEPARTMENT, TECHNICAL, STARTUP, ALUMNI
  reason      String?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  contact     CompanyContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  candidate   Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job         Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([contactId, candidateId, jobId])
  @@index([contactId])
  @@index([candidateId])
  @@index([jobId])
}

model ContactDiscoveryRun {
  id             String           @id @default(uuid())
  companyId      String?          @map("company_id")
  jobId          String?          @map("job_id")
  companyName    String           @map("company_name")
  status         String           @default("RUNNING") // RUNNING, COMPLETED, FAILED
  contactsFound  Int              @default(0) @map("contacts_found")
  contactsRanked Int              @default(0) @map("contacts_ranked")
  errors         String?
  duration       Int              @default(0) // processing time in ms
  successRate    Float            @default(0.0) @map("success_rate")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  // Relations
  company        Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  job            Job?             @relation(fields: [jobId], references: [id], onDelete: SetNull)
  contacts       CompanyContact[]

  @@index([companyId])
  @@index([jobId])
}

model OutreachTemplate {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  type            String   // REFERRAL_REQUEST, HIRING_MANAGER_EMAIL, RECRUITER_EMAIL, etc.
  subjectTemplate String?  @map("subject_template")
  bodyTemplate    String   @map("body_template")
  isSystem        Boolean  @default(true) @map("is_system")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([type])
}

model OutreachGenerationRun {
  id                    String          @id @default(uuid())
  jobId                 String?         @map("job_id")
  status                String          @default("RUNNING") // RUNNING, COMPLETED, FAILED
  draftsGenerated       Int             @default(0) @map("drafts_generated")
  averageQualityScore   Float           @default(0.0) @map("average_quality_score")
  expectedResponseRates Float           @default(0.0) @map("expected_response_rates")
  reviewRequiredCount   Int             @default(0) @map("review_required_count")
  errors                String?
  duration              Int             @default(0) // processing time in ms
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  // Relations
  drafts                OutreachDraft[]

  @@index([status])
}

model OutreachDraft {
  id                            String                 @id @default(uuid())
  jobId                         String                 @map("job_id")
  contactId                     String?                @map("contact_id")
  candidateId                   String                 @map("candidate_id")
  runId                         String?                @map("run_id")
  type                          String                 // REFERRAL_REQUEST, HIRING_MANAGER_EMAIL, RECRUITER_EMAIL, FOUNDER_EMAIL, CTO_EMAIL, ENGINEERING_MANAGER_EMAIL, THANK_YOU_MESSAGE, FOLLOW_UP_MESSAGE, LINKEDIN_DM
  status                        String                 @default("REVIEW_REQUIRED") // READY, REVIEW_REQUIRED, APPROVED, REJECTED
  subjectLines                  String[]               @map("subject_lines")
  selectedSubject               String?                @map("selected_subject")
  body                          String
  day3FollowUp                  String?                @map("day3_follow_up")
  day7FollowUp                  String?                @map("day7_follow_up")
  day14FollowUp                 String?                @map("day14_follow_up")
  qualityScore                  Int                    @map("quality_score")
  personalizationScore          Int                    @map("personalization_score")
  relevanceScore                Int                    @map("relevance_score")
  spamRiskScore                 Int                    @map("spam_risk_score")
  professionalismScore          Int                    @map("professionalism_score")
  clarityScore                  Int                    @map("clarity_score")
  expectedResponseProbability   Float                  @map("expected_response_probability")
  bestContactMessage            String?                @map("best_contact_message")
  bestOutreachType              String?                @map("best_outreach_type")
  outreachRecommendationReason   String?                @map("outreach_recommendation_reason")
  createdAt                     DateTime               @default(now()) @map("created_at")
  updatedAt                     DateTime               @updatedAt @map("updated_at")

  // Relations
  job                           Job                    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  contact                       CompanyContact?        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  candidate                     Candidate              @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  run                           OutreachGenerationRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  feedback                      OutreachFeedback[]

  @@index([jobId])
  @@index([contactId])
  @@index([candidateId])
  @@index([runId])
  @@index([status])
}

model OutreachFeedback {
  id        String        @id @default(uuid())
  draftId   String        @map("draft_id")
  rating    Int
  comments  String?
  processed Boolean       @default(false)
  createdAt DateTime      @default(now()) @map("created_at")

  // Relations
  draft     OutreachDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
}

model ResumeVersion {
  id              String               @id @default(uuid())
  jobId           String?              @map("job_id")
  candidateId     String               @map("candidate_id")
  companyName     String               @map("company_name")
  roleName        String               @map("role_name")
  versionName     String               @map("version_name") // GENERAL, STARTUP, BACKEND, FULL_STACK, AI_ENGINEER, FOUNDING_ENGINEER, DEVOPS
  filePath        String?              @map("file_path")
  markdownContent String               @map("markdown_content") @db.Text
  jsonContent     Json?                @map("json_content")
  atsScore        Float?               @map("ats_score")
  status          String               @default("PENDING") // PENDING, SUCCESS, FAILED
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  // Relations
  job             Job?                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate       Candidate            @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  optimizations   ResumeOptimization[]
  scores          ResumeScore[]
  keywords        ResumeKeyword[]
  applications    Application[]

  @@index([jobId])
  @@index([candidateId])
  @@index([versionName])
}

model ResumeOptimization {
  id               String        @id @default(uuid())
  resumeVersionId  String        @map("resume_version_id")
  resumeVersion    ResumeVersion @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)
  originalContent  String        @map("original_content") @db.Text
  optimizedContent String        @map("optimized_content") @db.Text
  rulesApplied     String[]      @default([]) @map("rules_applied")
  improvements     String[]      @default([])
  createdAt        DateTime      @default(now()) @map("created_at")

  @@index([resumeVersionId])
}

model ResumeKeyword {
  id              String        @id @default(uuid())
  resumeVersionId String        @map("resume_version_id")
  resumeVersion   ResumeVersion @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)
  keyword         String
  category        String        // PRIMARY, SECONDARY, INDUSTRY, ROLE, TECHNOLOGY
  status          String        // MATCHED, MISSING, HIGH_IMPACT
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([resumeVersionId])
  @@index([keyword])
  @@index([category])
  @@index([status])
}

model ResumeScore {
  id                         String        @id @default(uuid())
  resumeVersionId            String        @map("resume_version_id")
  resumeVersion              ResumeVersion @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)
  overallScore               Float         @map("overall_score")
  keywordMatchScore          Float         @map("keyword_match_score")
  roleAlignmentScore         Float         @map("role_alignment_score")
  skillsMatchScore           Float         @map("skills_match_score")
  projectMatchScore          Float         @map("project_match_score")
  formattingScore            Float         @map("formatting_score")
  readabilityScore           Float         @map("readability_score")
  missingSkills              String[]      @default([]) @map("missing_skills")
  missingKeywords            String[]      @default([]) @map("missing_keywords")
  weakSections               String[]      @default([]) @map("weak_sections")
  improvementOpportunities   String[]      @default([]) @map("improvement_opportunities")
  createdAt                  DateTime      @default(now()) @map("created_at")

  @@index([resumeVersionId])
}

model ResumeGenerationRun {
  id          String    @id @default(uuid())
  jobId       String?   @map("job_id")
  candidateId String    @map("candidate_id")
  status      String    @default("RUNNING") // RUNNING, COMPLETED, FAILED
  errors      String?
  duration    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  job         Job?      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([candidateId])
  @@index([status])
}

enum ApplicationStatus {
  DISCOVERED
  SHORTLISTED
  READY_TO_APPLY
  APPLIED
  OUTREACH_SENT
  REPLIED
  PHONE_SCREEN
  TECHNICAL_ROUND
  SYSTEM_DESIGN
  TAKE_HOME
  MANAGER_ROUND
  FINAL_ROUND
  OFFER_RECEIVED
  OFFER_ACCEPTED
  OFFER_DECLINED
  REJECTED
  WITHDRAWN
  ARCHIVED
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
  NO_SHOW
}

enum OfferStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  NEGOTIATING
}

model ApplicationStage {
  id           String        @id @default(uuid())
  key          String        @unique
  name         String
  order        Int
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  applications Application[]
}

model Application {
  id              String                     @id @default(uuid())
  jobId           String                     @map("job_id")
  companyId       String?                    @map("company_id")
  resumeVersionId String?                    @map("resume_version_id")
  contactId       String?                    @map("contact_id")
  candidateId     String                     @map("candidate_id")
  appliedDate     DateTime?                  @map("applied_date")
  status          ApplicationStatus          @default(DISCOVERED)
  source          String?
  priority        Int                        @default(0)
  stageId         String?                    @map("stage_id")
  createdAt       DateTime                   @default(now()) @map("created_at")
  updatedAt       DateTime                   @updatedAt @map("updated_at")

  // Relations
  job             Job                        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  company         Company?                   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  resumeVersion   ResumeVersion?             @relation(fields: [resumeVersionId], references: [id], onDelete: SetNull)
  contact         CompanyContact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)
  candidate       Candidate                  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  stage           ApplicationStage?          @relation(fields: [stageId], references: [id], onDelete: SetNull)
  activities      ApplicationActivity[]
  interviews      Interview[]
  interviewRounds InterviewRound[]
  offers          Offer[]
  documents       ApplicationDocument[]
  notes           ApplicationNote[]
  reminders       ApplicationReminder[]
  statusHistory   ApplicationStatusHistory[]
  communications  Communication[]
  communicationThreads CommunicationThread[]
  followUpSchedules FollowUpSchedule[]

  @@index([jobId])
  @@index([companyId])
  @@index([resumeVersionId])
  @@index([contactId])
  @@index([candidateId])
  @@index([status])
  @@index([priority])
}

model ApplicationStatusHistory {
  id            String            @id @default(uuid())
  applicationId String            @map("application_id")
  oldStatus     ApplicationStatus? @map("old_status")
  newStatus     ApplicationStatus @map("new_status")
  changedAt     DateTime          @default(now()) @map("changed_at")
  changedBy     String            @default("USER") @map("changed_by")
  reason        String?
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model ApplicationActivity {
  id            String      @id @default(uuid())
  applicationId String      @map("application_id")
  activityType  String      @map("activity_type")
  title         String
  description   String?
  metadata      Json?
  createdAt     DateTime    @default(now()) @map("created_at")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([createdAt])
}

model InterviewRound {
  id            String      @id @default(uuid())
  applicationId String      @map("application_id")
  roundName     String      @map("round_name")
  status        String      @default("PENDING")
  order         Int
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  interviews    Interview[]

  @@index([applicationId])
}

model Interview {
  id              String          @id @default(uuid())
  applicationId   String          @map("application_id")
  roundId         String?         @map("round_id")
  roundName       String          @map("round_name")
  interviewerName String?         @map("interviewer_name")
  interviewerRole String?         @map("interviewer_role")
  scheduledAt     DateTime        @map("scheduled_at")
  duration        Int
  meetingLink     String?         @map("meeting_link")
  notes           String?
  feedback        String?
  status          InterviewStatus @default(SCHEDULED)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  application     Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  round           InterviewRound? @relation(fields: [roundId], references: [id], onDelete: SetNull)

  @@index([applicationId])
  @@index([roundId])
}

model Offer {
  id             String      @id @default(uuid())
  applicationId  String      @map("application_id")
  baseSalary     Float?      @map("base_salary")
  bonus          Float?      @map("bonus")
  equity         String?
  joiningBonus   Float?      @map("joining_bonus")
  benefits       String?
  location       String?
  employmentType String?     @map("employment_type")
  offerDate      DateTime?   @map("offer_date")
  deadline       DateTime?
  status         OfferStatus @default(PENDING) @map("offer_status")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  // Relations
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model ApplicationDocument {
  id            String      @id @default(uuid())
  applicationId String      @map("application_id")
  documentType  String      @map("document_type")
  title         String
  filePath      String?     @map("file_path")
  fileSize      Int?        @map("file_size")
  mimeType      String?     @map("mime_type")
  metadata      Json?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // Relations
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model ApplicationNote {
  id            String      @id @default(uuid())
  applicationId String      @map("application_id")
  noteType      String      @map("note_type")
  content       String      @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // Relations
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model ApplicationReminder {
  id            String      @id @default(uuid())
  applicationId String      @map("application_id")
  reminderType  String      @map("reminder_type")
  title         String
  description   String?
  dueDate       DateTime    @map("due_date")
  status        String      @default("PENDING")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // Relations
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([dueDate])
  @@index([status])
}

enum CommunicationType {
  REFERRAL_REQUEST
  HIRING_MANAGER_OUTREACH
  RECRUITER_OUTREACH
  FOUNDER_OUTREACH
  CTO_OUTREACH
  FOLLOW_UP
  THANK_YOU
  INTERVIEW_CONFIRMATION
  INTERVIEW_FOLLOW_UP
  GENERAL
}

enum CommunicationStatus {
  DRAFT
  APPROVED
  SCHEDULED
  SENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  FAILED
  CANCELLED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum ResponseCategory {
  POSITIVE
  INTERESTED
  REFERRAL_PROVIDED
  INTERVIEW_REQUEST
  FOLLOW_UP_REQUEST
  NOT_INTERESTED
  REJECTED
  OUT_OF_OFFICE
  UNKNOWN
}

model CommunicationThread {
  id            String             @id @default(uuid())
  applicationId String?            @map("application_id")
  contactId     String?            @map("contact_id")
  companyId     String?            @map("company_id")
  subject       String
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  // Relations
  application   Application?       @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  contact       CompanyContact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company       Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  messages      CommunicationMessage[]
  communications Communication[]
  followUps     FollowUpSchedule[]

  @@index([applicationId])
  @@index([contactId])
  @@index([companyId])
}

model Communication {
  id              String               @id @default(uuid())
  threadId        String?              @map("thread_id")
  applicationId   String?              @map("application_id")
  contactId       String?              @map("contact_id")
  companyId       String?              @map("company_id")
  candidateId     String               @map("candidate_id")
  type            CommunicationType
  subject         String
  status          CommunicationStatus  @default(DRAFT)
  provider        String               @default("RESEND")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  // Relations
  thread          CommunicationThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  application     Application?         @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  contact         CompanyContact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company         Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  candidate       Candidate            @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  recipients      CommunicationRecipient[]
  deliveries      EmailDelivery[]
  replies         EmailReply[]

  @@index([threadId])
  @@index([applicationId])
  @@index([contactId])
  @@index([companyId])
  @@index([candidateId])
  @@index([status])
}

model CommunicationRecipient {
  id              String        @id @default(uuid())
  communicationId String        @map("communication_id")
  email           String
  role            String        @default("TO") // TO, CC, BCC
  createdAt       DateTime      @default(now()) @map("created_at")

  // Relations
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)

  @@index([communicationId])
}

model CommunicationMessage {
  id                String             @id @default(uuid())
  threadId          String             @map("thread_id")
  subject           String
  body              String             @db.Text
  direction         MessageDirection
  sentAt            DateTime?          @map("sent_at")
  receivedAt        DateTime?          @map("received_at")
  providerMessageId String?            @map("provider_message_id")
  status            String             @default("SENT")
  createdAt         DateTime           @default(now()) @map("created_at")

  // Relations
  thread            CommunicationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model EmailTemplate {
  id              String        @id @default(uuid())
  name            String        @unique
  description     String?
  category        String
  subjectTemplate String        @map("subject_template")
  bodyTemplate    String        @map("body_template") @db.Text
  variables       String[]      @default([])
  version         Int           @default(1)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
}

model EmailDelivery {
  id                String        @id @default(uuid())
  communicationId   String        @map("communication_id")
  providerMessageId String?        @map("provider_message_id")
  status            String        // SENT, DELIVERED, OPENED, CLICKED, BOUNCED, FAILED
  sentAt            DateTime?     @map("sent_at")
  deliveredAt       DateTime?     @map("delivered_at")
  openedAt          DateTime?     @map("opened_at")
  clickedAt         DateTime?     @map("clicked_at")
  bouncedAt         DateTime?     @map("bounced_at")
  failedAt          DateTime?     @map("failed_at")
  errorMessage      String?       @map("error_message")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relations
  communication     Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)

  @@index([communicationId])
}

model EmailReply {
  id              String           @id @default(uuid())
  communicationId String           @map("communication_id")
  content         String           @db.Text
  replyTimestamp  DateTime         @map("reply_timestamp")
  sentiment       String?
  responseCategory ResponseCategory @default(UNKNOWN) @map("response_category")
  confidence      Float            @default(1.0)
  createdAt       DateTime         @default(now()) @map("created_at")

  // Relations
  communication   Communication    @relation(fields: [communicationId], references: [id], onDelete: Cascade)

  @@index([communicationId])
}

model FollowUpSchedule {
  id            String             @id @default(uuid())
  threadId      String             @map("thread_id")
  applicationId String?            @map("application_id")
  contactId     String?            @map("contact_id")
  sequence      Int
  scheduledAt   DateTime           @map("scheduled_at")
  status        String             @default("PENDING") // PENDING, SENT, CANCELLED, SKIPPED
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  // Relations
  thread        CommunicationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  application   Application?        @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  contact       CompanyContact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([threadId])
  @@index([applicationId])
  @@index([contactId])
}

model CommunicationAnalytics {
  id          String   @id @default(uuid())
  metricName  String   @unique @map("metric_name")
  metricValue Float    @map("metric_value")
  updatedAt   DateTime @updatedAt @map("updated_at")
}




